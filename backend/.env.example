# Database URL (SQLite fallback is built-in if missing)
# For Postgres use: postgresql://username:password@localhost:5432/attendancedb
DATABASE_URL=sqlite:///attendance.db

# JWT Secret Key for token signing
JWT_SECRET_KEY=dev-secret-key-change-in-production

# Maximum file upload size in bytes (e.g. 5MB = 5 * 1024 * 1024)
MAX_UPLOAD_SIZE=5242880

# Base upload folder path
UPLOAD_FOLDER=uploads
